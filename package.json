{
  "name": "rs-tas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "pnpm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply rs-tas --local",
    "db:migrate:remote": "wrangler d1 migrations apply rs-tas --remote",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "dexie": "^4.2.1",
    "hono": "^4.10.4",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.6",
    "workbox-window": "^7.4.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@cloudflare/workers-types": "^4.20260620.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.0.8",
    "wrangler": "^4.50.0"
  }
}
