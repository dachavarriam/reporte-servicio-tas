<t t-name="studio_report_document">
    <t t-set="o" t-value="doc"/>

    <div class="page">
        <style>
            .manual-header {
                width: 100% !important;
                border-bottom: 1px solid #dddddd !important;
                 padding-bottom: 10px !important;
                 margin-bottom: 18px !important;
            }

            .manual-header-table {
                width: 100% !important;
                border-collapse: collapse !important;
            }

            .manual-header-table td {
                border: none !important;
                vertical-align: middle !important;
                padding: 0 !important;
            }

            .manual-logo-cell {
                width: 28% !important;
            }

            .manual-info-cell {
                width: 72% !important;
                text-align: right !important;
            }

            .manual-logo {
                max-height: 70px !important;
                max-width: 220px !important;
            }

            .manual-company-name {
                font-size: 17px !important;
                font-weight: 700 !important;
                margin: 0 !important;
                line-height: 1.2 !important;
            }

            .manual-company-info {
                font-size: 11px !important;
                color: #555555 !important;
                margin: 2px 0 0 0 !important;
                line-height: 1.25 !important;
            }
            
            .page {
                font-family: Arial, sans-serif !important;
                font-size: 12px !important;
                color: #222222 !important;
                line-height: 1.3 !important;
            }

            .report-title {
                margin-bottom: 16px !important;
            }

            .report-title h2 {
                margin: 0 0 4px 0 !important;
                font-size: 23px !important;
                font-weight: 700 !important;
                line-height: 1.2 !important;
            }

            .report-subtitle {
                color: #666666 !important;
                font-size: 12px !important;
                margin: 0 !important;
            }

            .info-box {
                width: 100% !important;
                border: 1px solid #dddddd !important;
                padding: 14px 16px !important;
                margin-top: 14px !important;
                margin-bottom: 18px !important;
                background-color: #fafafa !important;
                page-break-inside: avoid !important;
                box-sizing: border-box !important;
            }

            .info-table {
                width: 100% !important;
                border-collapse: collapse !important;
                table-layout: fixed !important;
            }

            .info-table td {
                width: 33.3333% !important;
                vertical-align: top !important;
                padding: 6px 14px 10px 6px !important;
                border: none !important;
                font-size: 12px !important;
            }

            .info-table td:first-child {
                padding-left: 8px !important;
            }

            .info-table strong {
                display: block !important;
                font-size: 11.5px !important;
                color: #555555 !important;
                margin-bottom: 3px !important;
            }

            .info-table p {
                margin: 0 !important;
                font-size: 12.5px !important;
                line-height: 1.35 !important;
            }

            .status-pill {
                display: inline-block !important;
                padding: 3px 8px !important;
                border-radius: 10px !important;
                font-size: 11px !important;
                font-weight: 700 !important;
            }

            .status-yes {
                background-color: #e8f5e9 !important;
                color: #2e7d32 !important;
            }

            .status-no {
                background-color: #fff3e0 !important;
                color: #ef6c00 !important;
            }

            .o_main_table {
                width: 100% !important;
                table-layout: fixed !important;
                border-collapse: collapse !important;
                margin-top: 16px !important;
            }

            .o_main_table th,
            .o_main_table td {
                font-size: 10.8px !important;
                line-height: 1.25 !important;
                vertical-align: top !important;
                padding: 6px 4px !important;
                border: none !important;
                word-wrap: break-word !important;
                overflow-wrap: break-word !important;
            }

            .o_main_table th {
                white-space: normal !important;
                background-color: #f2f2f2 !important;
                border-bottom: 1px solid #cccccc !important;
                font-weight: 700 !important;
            }

            .o_main_table .item-row td {
                background-color: #ffffff !important;
                border-bottom: 1px solid #eeeeee !important;
            }

            .o_main_table .item-row-alt td {
                background-color: #f7f7f7 !important;
                border-bottom: 1px solid #eeeeee !important;
            }

            .section-row td {
                background-color: #e9ecef !important;
                border-top: 1px solid #cccccc !important;
                border-bottom: 1px solid #cccccc !important;
                font-weight: 700 !important;
                color: #333333 !important;
                padding: 7px 6px !important;
                text-transform: uppercase !important;
                letter-spacing: 0.3px !important;
            }

            .col-num {
                width: 4% !important;
            }

            .col-model {
                width: 17% !important;
            }

            .col-description {
                width: 29% !important;
            }

            .col-sale-order {
                width: 14% !important;
            }

            .col-qty {
                width: 9% !important;
            }

            .col-stock {
                width: 13% !important;
            }

            .col-buy {
                width: 14% !important;
            }

            .summary-box {
                margin-top: 18px !important;
                border: 1px solid #dddddd !important;
                padding: 10px 12px !important;
                background-color: #fafafa !important;
                page-break-inside: avoid !important;
            }

            .summary-box strong {
                font-size: 13px !important;
            }

            .summary-box table {
                width: 100% !important;
                margin-top: 6px !important;
                border-collapse: collapse !important;
            }

            .summary-box td {
                font-size: 12px !important;
                padding: 3px 0 !important;
                border: none !important;
            }

            .text-muted-small {
                color: #666666 !important;
                font-size: 11.5px !important;
                margin-top: 14px !important;
            }

            .text-center {
                text-align: center !important;
            }

            .text-start {
                text-align: left !important;
            }

            .text-end {
                text-align: right !important;
            }
        </style>
        
<div class="manual-header">
    <table class="manual-header-table">
        <tr>
            <td class="manual-logo-cell">
                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" class="manual-logo"/>
            </td>

            <td class="manual-info-cell">
                <p class="manual-company-name">
                    <span t-field="res_company.name"/>
                </p>

                <p class="manual-company-info" t-if="res_company.partner_id.street">
                    <span t-field="res_company.partner_id.street"/>
                </p>

                <p class="manual-company-info">
                    <t t-if="res_company.partner_id.city">
                        <span t-field="res_company.partner_id.city"/>
                    </t>
                    <t t-if="res_company.partner_id.country_id">
                        <span> - </span>
                        <span t-field="res_company.partner_id.country_id"/>
                    </t>
                </p>

                <p class="manual-company-info">
                    <t t-if="res_company.phone">
                        Tel: <span t-field="res_company.phone"/>
                    </t>
                    <t t-if="res_company.email">
                        <span> | </span>
                        <span t-field="res_company.email"/>
                    </t>
                </p>
            </td>
        </tr>
    </table>
</div>

        <div class="oe_structure"/>

        <!-- TÍTULO -->
        <div class="report-title">
            <h2>
                Disponibilidad de Equipos
                <t t-if="o.x_name">
                    # <span t-field="o.x_name"/>
                </t>
            </h2>
            <p class="report-subtitle">
                Reporte interno de productos requeridos para proceso de compra/importación.
            </p>
        </div>

        <!-- INFORMACIÓN GENERAL -->
        <div class="info-box">
            <table class="info-table">
                <tr>
                    <td>
                        <strong>Cliente:</strong>
                        <p t-if="o.x_studio_partner_id" t-field="o.x_studio_partner_id"/>
                        <p t-else="">-</p>
                    </td>

                    <td>
                        <strong># de Cotización:</strong>
                        <p t-if="o.x_studio_many2one_field_B1qso" t-field="o.x_studio_many2one_field_B1qso"/>
                        <p t-else="">-</p>
                    </td>

                    <td>
                        <strong>Tiempo de entrega:</strong>
                        <p t-if="o.x_studio_tiempo_de_entrega" t-field="o.x_studio_tiempo_de_entrega"/>
                        <p t-else="">-</p>
                    </td>
                </tr>

                <tr>
                    <td>
                        <strong>Orden de compra entregada:</strong>
                        <p>
                            <span t-if="o.x_studio_orden_de_compra_entregada" class="status-pill status-yes">
                                Sí
                            </span>
                            <span t-else="" class="status-pill status-no">
                                No
                            </span>
                        </p>
                    </td>

                    <td>
                        <strong>Anticipo:</strong>
                        <p>
                            <span t-if="o.x_studio_anticipo" class="status-pill status-yes">
                                Sí
                            </span>
                            <span t-else="" class="status-pill status-no">
                                No
                            </span>
                        </p>
                    </td>

                    <td>
                        <strong>Fecha de impresión:</strong>
                        <p>
                            <span t-esc="time.strftime('%d/%m/%Y')"/>
                        </p>
                    </td>
                </tr>
            </table>
        </div>

        <!-- TABLA DE PRODUCTOS -->
        <table class="table table-sm o_main_table table-borderless">
            <thead style="display: table-row-group">
                <tr>
                    <th class="text-center col-num">
                        <strong>#</strong>
                    </th>

                    <th class="text-start col-model">
                        <strong>Modelo / Nombre</strong>
                    </th>

                    <th class="text-start col-description">
                        <strong>Descripción</strong>
                    </th>

                    <th class="text-start col-sale-order">
                        <strong>Orden de compra</strong>
                    </th>

                    <th class="text-end col-qty">
                        <strong>Cantidad</strong>
                    </th>

                    <th class="text-end col-stock">
                        <strong>Disponible Stock</strong>
                    </th>

                    <th class="text-end col-buy">
                        <strong>Cantidad a Comprar</strong>
                    </th>
                </tr>
            </thead>

            <tbody>
                <t t-set="item_counter" t-value="0"/>

                <t t-if="o.x_pedido_de_compra_imp_line_ids_3675f">
                    <t t-foreach="o.x_pedido_de_compra_imp_line_ids_3675f" t-as="line">

                        <!-- LÍNEA SIN MODELO = SECCIÓN, SI DESCRIPCIÓN NO ES 'UNO' -->
                        <t t-if="not line.x_name and line.x_studio_descripcin and line.x_studio_descripcin.strip().lower() != 'uno'">
                            <tr class="section-row">
                                <td colspan="7">
                                    <span t-field="line.x_studio_descripcin"/>
                                </td>
                            </tr>
                        </t>

                        <!-- LÍNEA CON MODELO = ÍTEM NORMAL -->
                        <t t-if="line.x_name">
                            <t t-set="item_counter" t-value="item_counter + 1"/>

                            <tr t-att-class="'item-row item-row-alt' if item_counter % 2 == 0 else 'item-row'">
                                <td class="text-center">
                                    <span t-esc="item_counter"/>
                                </td>

                                <td class="text-start">
                                    <span t-field="line.x_name"/>
                                </td>

                                <td class="text-start">
                                    <span t-if="line.x_studio_descripcin" t-field="line.x_studio_descripcin"/>
                                    <span t-else="">-</span>
                                </td>

                                <td class="text-start">
                                    <span t-if="line.x_studio_many2one_field_KeMdl" t-field="line.x_studio_many2one_field_KeMdl"/>
                                    <span t-else="">-</span>
                                </td>

                                <td class="text-end">
                                    <span t-if="line.x_studio_cantidad" t-field="line.x_studio_cantidad"/>
                                    <span t-else="">0</span>
                                </td>

                                <td class="text-end">
                                    <span t-if="line.x_studio_disponible_stock" t-field="line.x_studio_disponible_stock"/>
                                    <span t-else="">0</span>
                                </td>

                                <td class="text-end">
                                    <strong>
                                        <span t-if="line.x_studio_cantidad_a_comprar" t-field="line.x_studio_cantidad_a_comprar"/>
                                        <span t-else="">0</span>
                                    </strong>
                                </td>
                            </tr>
                        </t>

                    </t>
                </t>

                <t t-else="">
                    <tr>
                        <td colspan="7" class="text-center">
                            No hay productos registrados en este pedido de importación.
                        </td>
                    </tr>
                </t>

                <t t-if="o.x_pedido_de_compra_imp_line_ids_3675f and item_counter == 0">
                    <tr>
                        <td colspan="7" class="text-center">
                            No hay ítems con modelo registrados para comprar.
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>

        <!-- RESUMEN SIMPLE -->
        <div class="summary-box" t-if="o.x_pedido_de_compra_imp_line_ids_3675f.filtered(lambda l: l.x_name)">
            <strong>Resumen del pedido:</strong>

            <table>
                <tr>
                    <td>Total de ítems:</td>
                    <td class="text-end">
                        <span t-esc="len(o.x_pedido_de_compra_imp_line_ids_3675f.filtered(lambda l: l.x_name))"/>
                    </td>
                </tr>

                <tr>
                    <td>Total cantidad solicitada:</td>
                    <td class="text-end">
                        <span t-esc="sum(o.x_pedido_de_compra_imp_line_ids_3675f.filtered(lambda l: l.x_name).mapped('x_studio_cantidad'))"/>
                    </td>
                </tr>

                <tr>
                    <td>Total disponible en stock:</td>
                    <td class="text-end">
                        <span t-esc="sum(o.x_pedido_de_compra_imp_line_ids_3675f.filtered(lambda l: l.x_name).mapped('x_studio_disponible_stock'))"/>
                    </td>
                </tr>

                <tr>
                    <td>
                        <strong>Total a comprar:</strong>
                    </td>
                    <td class="text-end">
                        <strong>
                            <span t-esc="sum(o.x_pedido_de_compra_imp_line_ids_3675f.filtered(lambda l: l.x_name).mapped('x_studio_cantidad_a_comprar'))"/>
                        </strong>
                    </td>
                </tr>
            </table>
        </div>

        <p class="text-muted-small">
            Este documento es de uso interno y sirve como referencia para preparar el proceso de compra/importación.
        </p>

<div class="manual-footer">
    <table style="width:100%; border-top:1px solid #dddddd; margin-top:18px; padding-top:6px;">
        <tr>
            <td style="font-size:10.5px; color:#666666; text-align:left;">
                Documento interno generado desde Odoo
            </td>
            <td style="font-size:10.5px; color:#666666; text-align:right;">
                <span t-esc="time.strftime('%d/%m/%Y')"/>
            </td>
        </tr>
    </table>
</div>

        <div class="oe_structure"/>
    </div>
</t>